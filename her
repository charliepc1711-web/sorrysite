<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>For You ❤️</title>

<style>
body {
    margin: 0;
    padding: 0;
    background: linear-gradient(to right, #1a1a1a, #333);
    color: white;
    font-family: 'Segoe UI', sans-serif;
    text-align: center;
}

.container {
    margin-top: 15%;
}

h1 {
    font-size: 40px;
    color: #ff4d6d;
}

p {
    font-size: 20px;
    width: 70%;
    margin: auto;
    margin-top: 20px;
    line-height: 1.6;
}

button {
    margin-top: 30px;
    padding: 10px 20px;
    border: none;
    background: #ff4d6d;
    color: white;
    font-size: 18px;
    cursor: pointer;
    border-radius: 10px;
}
</style>
</head>

<body>

<div class="container">
    <h1 id="name">Hey...</h1>
    <p id="message"></p>
    
    <button onclick="playMusic()">Play something for you 🎶</button>
</div>

<!-- YouTube hidden audio -->
<iframe id="music" width="0" height="0"
src="https://www.youtube.com/embed/1G4isv_Fylg?enablejsapi=1"
frameborder="0"></iframe>

<script>
let text = "I know you're angry with me... and honestly, I deserve it. I didn't mean to hurt you. You really matter to me more than I say. I'm sorry... truly. If you can, give me one chance to make things right.";

let i = 0;
function typing() {
    if (i < text.length) {
        document.getElementById("message").innerHTML += text.charAt(i);
        i++;
        setTimeout(typing, 40);
    }
}
typing();

function playMusic() {
    document.getElementById("music").src += "&autoplay=1";
}
</script>

